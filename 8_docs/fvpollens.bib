@article{meeusMultiplexPCRDetection2010b,
  title = {Multiplex {{PCR Detection}} of {{Slowly-Evolving Trypanosomatids}} and {{Neogregarines}} in {{Bumblebees Using Broad-Range Primers}}},
  author = {Meeus, I. and De Graaf, D.c. and Jans, K. and Smagghe, G.},
  date = {2010},
  journaltitle = {Journal of Applied Microbiology},
  volume = {109},
  number = {1},
  pages = {107--115},
  issn = {1365-2672},
  doi = {10.1111/j.1365-2672.2009.04635.x},
  abstract = {Aims: The aims of this study were to design universal markers for different protozoan parasites of Bombus spp. based on the phylogenetic position of two important bumblebee parasites Crithidia bombi and Apicystis bombi. Methods and Results: Standard PCR and extraction techniques were used to amplify and sequence 18S rDNA. Phylogenetic analysis of the rDNA was performed in order to predict the parasite range of the primers. Conclusions: Crithidia bombi phylogenetically clusters with the trypanosomatids with slowly-evolving SSU-rRNA sequences (SE), while A. bombi is the closest sister group of Mattesia. A multiplex was designed containing an internal control and two broad-range primer pairs, detecting C. bombi and other SE trypanosomatids and also A. bombi and other neogregarines. Significance and Impact of the Study: Sequence data generated will further improve the current systematics of insect trypanosomatids and gregarines that remain troublesome. Broad-range markers for bumblebee parasites are necessary tools enabling the screening of commercially imported colonies and thus controlling their worldwide distribution and to discover related emerging parasites.},
  keywords = {18S rDNA,Apicystis bombi,Crithidia bombi,phylogeny,protozoa detection}
}

@online{melansonAgriculturalIntensificationFavours2026,
  title = {Agricultural Intensification Favours an Introduced Bumble Bee over Its Native Congener through Differences in Foraging Range, Habitat Association, and Lineage Continuity},
  author = {Melanson, Jenna B. and Kelly, Tyler T. and Clermont, Natalia and Koch, Jonathan B. Uhuad and Kremen, Claire},
  date = {2026-05-12},
  eprinttype = {bioRxiv},
  eprintclass = {New Results},
  pages = {2026.05.07.723627},
  issn = {2692-8205},
  doi = {10.64898/2026.05.07.723627},
  url = {https://www.biorxiv.org/content/10.64898/2026.05.07.723627v1},
  urldate = {2026-05-14},
  abstract = {{$<$}p{$>$}1. Agricultural intensification can support the expansion of introduced species which are highly adapted to human-modified landscapes, but the mechanisms by which this occurs are often unclear. 2. Here we investigate the spatial ecology of a rapidly expanding introduced bumble bee (\mkbibemph{Bombus impatiens}) and a native congener (\mkbibemph{B. mixtus}) in agricultural landscapes of southwestern British Columbia, Canada. We used microsatellite genotyping and spatially explicit capture-recapture models to compare the foraging distance of the two species, and fitted hierarchical models to compare their abundance, behaviour (nest searching vs foraging), and lineage survival as a function of landscape composition and configuration. 3. We found that \mkbibemph{B. impatiens} had a broader foraging range than \mkbibemph{B. mixtus}, and that its colony/worker abundance were positively associated with the surrounding area of residential gardens, but decreased relative to \mkbibemph{B. mixtus} abundance in response to increasing seminatural area. In contrast, \mkbibemph{B. mixtus} colony abundance decreased in landscapes with a greater area of intensively managed berry crops. 4. We observed fewer \mkbibemph{B. impatiens} queens per survey in landscapes with more low-disturbance landcover, and hypothesize space use of this species could be shaped by concentration on potential nesting habitat. Consistent with this observation, nest searching behaviour was more common for \mkbibemph{B. impatiens} queens, while \mkbibemph{B. mixtus} queens were primarily observed foraging, suggesting these two species derive different value from agricultural landscapes during colony establishment. 5. Finally, we found that the rate of lineage re-capture between 2022 colonies and 2023 spring queens was nearly 10-fold higher for \mkbibemph{B. impatiens} than for \mkbibemph{B. mixtus}, indicating a greater capacity of the introduced species to complete its life cycle in agro-natural landscape mosaics. 6. Our results suggest that differences in spatial ecology may contribute to the differential success of these two species in human-modified landscapes, and provide insight into the mechanisms by which land-use change shapes community composition.{$<$}/p{$>$}},
  langid = {english},
  pubstate = {prepublished},
  file = {/Users/jenna1/Zotero/storage/X8T2LXI9/Melanson et al. - 2026 - Agricultural intensification favours an introduced bumble bee over its native congener through diffe.pdf}
}

