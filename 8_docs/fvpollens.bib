@article{reberfunkMicrosatelliteLociBombus2006a,
  title = {Microsatellite {{Loci}} for {{Bombus Spp}}.},
  author = {Reber Funk, Christine and Schmid-Hempel, Regula and Schmid-Hempel, Paul},
