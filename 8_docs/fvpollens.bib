@article{cooleyBuzzPollinatedCropsGlobal2021,
  title = {Buzz-{{Pollinated Crops}}: {{A Global Review}} and {{Meta-analysis}} of the {{Effects}} of {{Supplemental Bee Pollination}} in {{Tomato}}},
  shorttitle = {Buzz-{{Pollinated Crops}}},
  author = {Cooley, Hazel and Vallejo-Marín, Mario},
